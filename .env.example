# Copy this file to .env.local and fill in your Supabase credentials.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Browser-safe app-owned data proxy/base URL for NoCodeBackend table endpoints.
VITE_NOCODEBACKEND_API_BASE_URL=/api/nocodebackend

# Server-side only. Do not expose this with a VITE_ prefix.
NOCODEBACKEND_SECRET_KEY=
