# Copy this file to .env.local. Do not commit .env.local or real credentials.
# Browser-safe data endpoint. The default expects an app/deployment-provided data route.
VITE_NOCODEBACKEND_API_BASE_URL=/api/nocodebackend

# Optional browser-safe auth-proxy override. Leave unset to use /api/nocodebackend/auth.
# VITE_NOCODEBACKEND_AUTH_BASE_URL=/api/nocodebackend/auth

# Server-only: configure in the serverless/deployment environment, never with VITE_ prefix.
NOCODEBACKEND_SECRET_KEY=
